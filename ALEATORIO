//Generacion de numeros aleatorios (pseudoaleatorios)


#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;

int main() {
	srand(time(NULL)); //Crea la semilla
	int aleatorio;

	aleatorio = rand(); //Generacion de un valor aleatorio 0 y 32767
	cout << "valor aleatorio 0 y 32767 : " << aleatorio << endl;

	aleatorio = rand() % 101; //Aleatorio entre 1 y 100
	cout << "valor aleatorio 0 y 100 : " << aleatorio << endl;

	aleatorio = rand() % 50 + 1; //Aleatorio entre 1 y 50
	cout << "valor aleatorio 0 y 50 : " << aleatorio << endl;

	aleatorio = rand() % 30 + 50; //Aleatorio entre 1 y 50
	cout << "valor aleatorio 50 y 80 : " << aleatorio << endl;

	cout << "\nCalificaciones de programacion: ";
	int suma = 0, cal;

	for(int i = 0; i < 10; i++) {
		cal = rand() % 10 + 1;
		cout << cal << ", ";
		suma += cal;

	}
	int promedio = suma / 10;

	cout << "\nEl promedio es : " << promedio << endl;
	return 0;
}
